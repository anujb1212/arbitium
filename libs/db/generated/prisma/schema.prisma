generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

enum TransferDirection {
  DEPOSIT
  WITHDRAW
}

enum TransferStatus {
  PENDING
  COMPLETED
  FAILED
}

enum KlineInterval {
  ONE_MINUTE
  FIVE_MINUTES
  FIFTEEN_MINUTES
  ONE_HOUR
  ONE_DAY
}

model User {
  id                   String   @id @default(cuid())
  vaultlyUserId        String   @unique
  email                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  welcomeBonusCredited Boolean  @default(false)

  tradingBalance TradingBalance?
  orders         Order[]
  transfers      BalanceTransfer[]

  @@index([vaultlyUserId])
}

model TradingBalance {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  available BigInt @default(0)
  locked    BigInt @default(0)

  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Order {
  id     String @id
  userId String
  user   User   @relation(fields: [userId], references: [id])

  market    String
  side      OrderSide
  price     BigInt
  qty       BigInt
  filledQty BigInt    @default(0)

  status OrderStatus @default(OPEN)

  lockedAmount BigInt
  commandId    String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades      Trade[] @relation("MakerTrades")
  takerTrades Trade[] @relation("TakerTrades")

  @@index([userId, status])
  @@index([market, status])
  @@index([commandId])
}

model Trade {
  id     String @id @default(cuid())
  market String

  makerOrderId String
  takerOrderId String
  makerOrder   Order  @relation("MakerTrades", fields: [makerOrderId], references: [id])
  takerOrder   Order  @relation("TakerTrades", fields: [takerOrderId], references: [id])

  price     BigInt
  qty       BigInt
  takerSide OrderSide

  executedAt DateTime @default(now())

  @@unique([makerOrderId, takerOrderId])
  @@index([market, executedAt])
  @@index([makerOrderId])
  @@index([takerOrderId])
}

model BalanceTransfer {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  direction     TransferDirection
  amountInPaise BigInt
  status        TransferStatus    @default(PENDING)

  idempotencyKey String  @unique
  vaultlyRef     String?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([userId, direction])
  @@index([idempotencyKey])
}

model Kline {
  id       String        @id @default(cuid())
  market   String
  interval KlineInterval

  openTime  DateTime
  closeTime DateTime

  open   BigInt
  high   BigInt
  low    BigInt
  close  BigInt
  volume BigInt

  tradeCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([market, interval, openTime])
  @@index([market, interval, openTime])
}
